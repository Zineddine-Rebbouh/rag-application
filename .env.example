# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Your project URL from: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key (safe to use in backend — RLS enforces row-level access)
# From: Project Settings → API → Project API keys → anon/public
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key (NEVER expose to frontend — bypasses RLS)
# From: Project Settings → API → Project API keys → service_role
# Only needed if you later add admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT secret — used to verify user tokens server-side
# From: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─────────────────────────────────────────────
# Groq
# ─────────────────────────────────────────────
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Model to use. Verify current name at: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# LangSmith
# ─────────────────────────────────────────────
# Sign up at: https://smith.langchain.com
# Get API key from: Settings → API Keys
LANGSMITH_API_KEY=your-langsmith-api-key

# Set to "true" to enable tracing (set "false" to disable without removing key)
LANGCHAIN_TRACING_V2=true

# Name of the LangSmith project traces will appear under
LANGCHAIN_PROJECT=rag-application-module1

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# Origins allowed for CORS (comma-separated). Typically your frontend dev URL.
ALLOWED_ORIGINS=http://localhost:5173

# Context window token budget for conversation history (safe default: 6000)
CONTEXT_WINDOW_TOKENS=6000
